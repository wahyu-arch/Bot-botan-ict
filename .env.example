# ============================================================
# BOT BOTAN ICT — Environment Variables
# Copy file ini ke .env dan isi nilainya
# ============================================================

# ============================
# WAJIB — Groq AI
# Daftar di https://console.groq.com
# Gunakan 4 key berbeda agar tidak saling berbagi limit
# ============================
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx         # Hiura (H1 analyst)
GROQ_API_KEY_AI1=gsk_xxxxxxxxxxxxxxxxxxxx     # Senanan (IDM hunter)
GROQ_API_KEY_AI2=gsk_xxxxxxxxxxxxxxxxxxxx     # Shina (BOS/MSS guard)
GROQ_API_KEY_AI3=gsk_xxxxxxxxxxxxxxxxxxxx     # Yusuf (entry sniper)

# Model per AI — pakai model BERBEDA agar limit tidak shared!
GROQ_MODEL_MAIN=llama-3.3-70b-versatile       # Hiura
GROQ_MODEL_AI1=llama-3.3-70b-versatile        # Senanan
GROQ_MODEL_AI2=llama3-70b-8192                # Shina (limit terpisah)
GROQ_MODEL_AI3=gemma2-9b-it                   # Yusuf (limit terpisah)
GROQ_MODEL_JSON=llama3-70b-8192               # Fallback JSON output

# ============================
# WAJIB — Bybit API
# Daftar di https://www.bybit.com/app/user/api-management
# Permission yang dibutuhkan: Read + Trade (Derivatives)
# ============================
BYBIT_API_KEY=xxxxxxxxxxxxxxxxxx
BYBIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BYBIT_TESTNET=false           # true=testnet, false=mainnet LIVE

# ============================
# OPSIONAL — Katyusha (Supervisor)
# Bisa dimatikan via toggle di dashboard tanpa hapus key ini
# Daftar di https://openrouter.ai
# ============================
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
KATYUSHA_MODEL=anthropic/claude-sonnet-4-6

# ============================
# TRADING
# ============================
TRADING_SYMBOL=BTCUSDT        # Symbol Bybit Futures: BTCUSDT, DOGEUSDT, dll
PAPER_TRADING=true            # true=paper (tidak kirim order real), false=live
LEVERAGE=10                   # Leverage futures (default 10x)
SCAN_INTERVAL_SECONDS=0       # 0=sync ke M5 candle close Bybit (REKOMENDASI), angka lain=manual

# ============================
# RISK MANAGEMENT
# Risk per trade = 1% FIXED dari balance
# ============================
ACCOUNT_BALANCE=10000         # Balance awal USD (auto-sync dari Bybit saat live)
MAX_QTY=100000                # Max qty — naikkan untuk koin harga kecil (DOGE, XVG, dll)
MIN_QTY=1                     # Min qty Bybit (biasanya 1 untuk koin kecil)

# ============================
# DATA SOURCE
# ============================
DATA_SOURCE=bybit             # bybit=live klines | mock=testing tanpa internet

# ============================
# MULTI-SYMBOL (opsional)
# Kalau diisi, TRADING_SYMBOL di atas diabaikan
# Jalankan beberapa symbol sekaligus (rate limit aware)
# ============================
# TRADING_SYMBOLS=BTCUSDT,DOGEUSDT,FARTCOINUSDT

# ============================
# CATATAN PINDAH PLATFORM
# ============================
# Saat pindah dari Railway/Render/Fly.io:
# 1. Download/backup semua file di data/ folder
#    (rules.json, logic_rules.json, prompts.json, state.json, watchlist.json)
# 2. Set env variables di platform baru
# 3. Upload file data/ ke persistent storage platform baru
# 4. Port yang digunakan: 8080
