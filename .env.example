# ============================
# WAJIB - Groq AI (utama / analisis ICT)
# ============================
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ============================
# AI PANEL — 3 Analis Tambahan
# Jika tidak diisi, otomatis fallback ke GROQ_API_KEY di atas
# Sebaiknya gunakan 3 API key berbeda agar tidak kena rate limit
# ============================
GROQ_API_KEY_AI1=gsk_xxxxxxxxxxxxxxxxxxxx   # AI-1: Mental Model & Strategi Berpikir
GROQ_API_KEY_AI2=gsk_xxxxxxxxxxxxxxxxxxxx   # AI-2: Komponen Kognitif
GROQ_API_KEY_AI3=gsk_xxxxxxxxxxxxxxxxxxxx   # AI-3: Karakteristik Pola Pikir (Mindset)

# ============================
# WAJIB - Bybit API
# ============================
BYBIT_API_KEY=xxxxxxxxxxxxxxxxxx
BYBIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BYBIT_TESTNET=true          # true=testnet, false=mainnet LIVE

# ============================
# KONFIGURASI TRADING
# ============================
TRADING_SYMBOL=BTCUSDT        # Symbol Bybit Linear Perp: BTCUSDT, ETHUSDT, SOLUSDT, dll
PAPER_TRADING=true            # true=paper (tidak kirim order), false=live ke Bybit
SCAN_INTERVAL_SECONDS=60      # Interval scan market (detik)
MAX_AI_ITERATIONS=3           # Max iterasi self-correction AI

# ============================
# MANAJEMEN RISIKO (1% FIXED)
# ============================
# Risk per trade = 1% FIXED (hardcoded, tidak bisa diubah)
ACCOUNT_BALANCE=10000         # Balance awal USD (akan di-sync dari Bybit jika live)
MAX_QTY=1.0                   # Maksimum qty per order (dalam koin base)
MIN_QTY=0.001                 # Minimum qty per order

# ============================
# SUMBER DATA MARKET
# ============================
# Pilihan: "bybit" (live/testnet klines) | "mock" (testing)
DATA_SOURCE=bybit
