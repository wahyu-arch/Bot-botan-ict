# ============================
# WAJIB - Groq AI (utama / analisis ICT)
# ============================
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ============================
# AI PANEL — 3 Analis Tambahan
# Jika tidak diisi, otomatis fallback ke GROQ_API_KEY di atas
# Sebaiknya gunakan 3 API key berbeda agar tidak kena rate limit
# ============================
GROQ_API_KEY_AI1=gsk_xxxxxxxxxxxxxxxxxxxx   # AI-1: Mental Model & Strategi Berpikir
GROQ_API_KEY_AI2=gsk_xxxxxxxxxxxxxxxxxxxx   # AI-2: Komponen Kognitif
GROQ_API_KEY_AI3=gsk_xxxxxxxxxxxxxxxxxxxx   # AI-3: Karakteristik Pola Pikir (Mindset)

# ============================
# WAJIB - Bybit API
# ============================
BYBIT_API_KEY=xxxxxxxxxxxxxxxxxx
BYBIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PENTING: Ganti ke false untuk akun REAL Bybit (bukan testnet)
BYBIT_TESTNET=false          # true=testnet, false=mainnet LIVE

# ============================
# KONFIGURASI TRADING
# ============================
# Multi-symbol (v29+): pisahkan dengan koma
# Jika diisi, TRADING_SYMBOL di bawah diabaikan
TRADING_SYMBOLS=BTCUSDT,DOGEUSDT,FARTCOINUSDT,XVGUSDT,1000BONKUSDT

# Single symbol (kompatibilitas lama — diabaikan jika TRADING_SYMBOLS diisi)
TRADING_SYMBOL=BTCUSDT

PAPER_TRADING=true            # true=paper (tidak kirim order), false=live ke Bybit
SCAN_INTERVAL_SECONDS=60      # Interval scan market (detik)
MAX_AI_ITERATIONS=3           # Max iterasi self-correction AI

# ============================
# MANAJEMEN RISIKO (1% FIXED)
# ============================
# Risk per trade = 1% FIXED (hardcoded, tidak bisa diubah)
ACCOUNT_BALANCE=10000         # Balance awal USD (akan di-sync dari Bybit jika live)
MAX_QTY=1.0                   # Maksimum qty per order (dalam koin base)
MIN_QTY=0.001                 # Minimum qty per order

# ============================
# MODEL GROQ PER KEY (opsional)
# Gunakan model BERBEDA per key agar limit tidak saling berbagi!
# Rekomendasi:
#   GROQ_MODEL_MAIN  = llama-3.3-70b-versatile  (Yusuf - analisis ICT utama)
#   GROQ_MODEL_AI1   = llama-3.3-70b-versatile  (Arka)
#   GROQ_MODEL_AI2   = llama-3.3-70b-versatile  (Nova)
#   GROQ_MODEL_AI3   = llama-3.3-70b-versatile  (Zara)
#
# Model gratis Groq yang tersedia (cek https://console.groq.com/docs/models):
#   llama-3.3-70b-versatile  — terbaik, tapi 1 limit per org
#   llama-3.1-8b-instant     — cepat, hemat token
#   llama3-70b-8192          — versi lama, limit terpisah
#   gemma2-9b-it             — Google model, limit sendiri
#   mixtral-8x7b-32768       — Mistral, limit sendiri
# ============================
# GROQ_MODEL_MAIN  = model untuk Yusuf bicara bebas (opening/closing diskusi)
#                    Boleh model apapun termasuk yang tidak support JSON mode
# GROQ_MODEL_JSON  = model untuk output JSON terstruktur (analisis ICT, watchlist)
#                    HARUS model yang bisa output JSON bersih
#                    Rekomendasi: llama3-70b-8192 atau llama-3.1-8b-instant
GROQ_MODEL_MAIN=openai/gpt-oss-120b
GROQ_MODEL_JSON=llama3-70b-8192
GROQ_MODEL_AI1=openai/gpt-oss-20b
GROQ_MODEL_AI2=qwen/qwen3-32b
GROQ_MODEL_AI3=qwen/qwen3-32b

# ============================
# KATYUSHA — Supervisor via OpenRouter (Claude Sonnet)
# Daftar di https://openrouter.ai/ — free tier tersedia
# ============================
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
# Model Katyusha via OpenRouter (default: Claude Sonnet)
KATYUSHA_MODEL=anthropic/claude-sonnet-4-6

# ============================
# SUMBER DATA MARKET
# ============================
# Pilihan: "bybit" (live/testnet klines) | "mock" (testing)
DATA_SOURCE=bybit
